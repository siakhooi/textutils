#!/usr/bin/env bash
#
# Description: Adds a suffix to each line of input.
# Usage: suffix [suffix] [inputFile]
#
set -Eeuo pipefail
shopt -s inherit_errexit

if [[ $# -ne 1 ]] && [[ $# -ne 2 ]]; then
	echo "Usage: $(basename "$0") suffix [inputFile]" >&2
	exit 1
fi

readonly SUFFIX="$1"

if [[ $# -eq 1 ]]; then
	readonly INFILE=/dev/stdin
else
	readonly INFILE="$2"
	if [[ ! -f "$INFILE" ]]; then
		echo "Error: Input file '$INFILE' does not exist or is not a file." >&2
		exit 1
	fi
	if [[ ! -r "$INFILE" ]]; then
		echo "Error: Input file '$INFILE' is not readable." >&2
		exit 1
	fi
fi

while IFS='' read -r line || [[ -n "$line" ]]; do
	printf '%s\n' "${line}${SUFFIX}"
done <"$INFILE"
